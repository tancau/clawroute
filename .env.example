# 后端配置
PORT=3000

# JWT 密钥 (用于签名认证 token)
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this

# 加密密钥 (用于加密 API Keys)
# 必须是 32 字节的 base64 编码字符串
# 生成方法: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# 副端配置
NEXT_PUBLIC_API_URL=http://localhost:3000

# 数据库路径 (可选)
# DATABASE_PATH=./data/clawrouter.db

# 允许无认证访问（开发模式）
ALLOW_NO_AUTH=true

# API Keys (根据需要配置)
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (性价比高)
DEEPSEEK_API_KEY=...

# OpenRouter (免费模型)
OPENROUTER_API_KEY=sk-or-...

# LiteLLM Proxy (本地)
LITELLM_URL=http://23.94.236.146:3000/v1
LITELLM_API_KEY=...

# Infini-AI
INFINI_AI_API_KEY=...

# Google
GOOGLE_API_KEY=...

# Qwen (Alibaba)
QWEN_API_KEY=...

# Mistral
MISTRAL_API_KEY=...

# 注意:
# - 生产环境请务必更换 JWT_SECRET 和 ENCRYPTION_KEY
# - API Keys 可在 Dashboard 中配置，不一定要写入环境变量
# - 支持多个 Key (用逗号分隔): OPENAI_API_KEY=sk-xxx,sk-yyy
