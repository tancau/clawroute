# 后端配置
PORT=3000

# JWT 密钥 (用于签名认证 token)
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this

# 加密密钥 (用于加密 API Keys)
# 必须是 32 字节的 base64 编码字符串
# 生成方法: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# 副端配置
NEXT_PUBLIC_API_URL=http://localhost:3000

# 数据库路径 (可选)
# DATABASE_PATH=./data/clawrouter.db

# API Keys (根据需要配置)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# QWEN_API_KEY=...
# MISTRAL_API_KEY=...
# GROK_API_KEY=...

# 注意:
# - 生产环境请务必更换 JWT_SECRET 和 ENCRYPTION_KEY
# - API Keys 可在 Dashboard 中配置，不一定要写入环境变量
# - 支持多个 Key (用逗号分隔): OPENAI_API_KEY=sk-xxx,sk-yyy
